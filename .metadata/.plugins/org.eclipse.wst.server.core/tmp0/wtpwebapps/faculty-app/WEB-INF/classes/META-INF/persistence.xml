<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.1">
    <persistence-unit name="myPersistenceUnit">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>model.entity.User</class>
        <class>model.entity.Vehicle</class>
        <class>model.entity.Rental</class>
        <class>model.entity.CarRental</class>
        <class>model.entity.Customer</class>
        <properties>
             <!-- Database Connection -->
		    <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
		    <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/intern"/>
		    <property name="jakarta.persistence.jdbc.user" value="student"/>
		    <property name="jakarta.persistence.jdbc.password" value="password"/>
		
		    <!-- Hibernate Settings -->
		    <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
		    <property name="hibernate.hbm2ddl.auto" value="update"/>
		    <property name="hibernate.show_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>