<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Card Layout</title>

   
    <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">

    
    <style>
        .card {
            transition: transform 0.3s ease-in-out;
        }

        .card:hover {
            transform: translateY(-10px);
        }

        .card-title {
            font-size: 1.2rem;
        }

        .card-text {
            font-size: 0.9rem;
        }

        .btn {
            width: 100%;
        }

        .container {
            margin-top: 30px;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row">
        
        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content">
                    <span class="card-title">Internship Managment</span>
                </div>
                <div class="card-action">
                    <a href="internships" class="btn waves-effect waves-light">Action</a>
                </div>
            </div>
        </div>

       
        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content">
                    <span class="card-title">Review Applied Students</span>
                </div>
                <div class="card-action">
                    <a href="applications.jsp" class="btn waves-effect waves-light">Action</a>
                </div>
            </div>
        </div>

      
        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content">
                    <span class="card-title">Evaluate Student</span>
                </div>
                <div class="card-action">
                    <a href="evaluateStudent.jsp" class="btn waves-effect waves-light">Action</a>
                </div>
            </div>
        </div>

       
        <div class="col s12 m6 l3">
            <div class="card hoverable">
                <div class="card-content">
                    <span class="card-title">Account Settings</span>
                    <p>Update your account</p>
                </div>
                <div class="card-action">
                    <a href="account" class="btn waves-effect waves-light">Action</a>
                </div>
            </div>
        </div>
    </div>
</div>

<% String message = (String) request.getAttribute("message"); %>
<script>
    const message = "<%= message %>";
    if (message === "password_update") {
        alert("Password has been updated!");
    }
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>
